{
  "app": "python app.py",
  "watch": {
    "include": ["**"],
    "exclude": [
      "README.md",
      "cdk*.json",
      "**/__pycache__/**",
      "**/.venv/**",
      "**/node_modules/**"
    ]
  },
  "context": {
    "@aws-cdk/aws-lambda:recognizeLayerVersion": true,
    "@aws-cdk/core:checkSecretUsage": true,
    "prefix": "myteam",
    "timezone_name": "IST",
    "timezone_offset_hours": 5,
    "timezone_offset_minutes": 30,
    "foundation_model": "us.anthropic.claude-sonnet-4-6",
    "idle_session_ttl": 600,
    "lambda_timeout": 10
  }
}
